<%- include('partials/header') %>

<div class="p-6 max-w-md mx-auto bg-white mt-10 rounded shadow">
  <h2 class="text-xl font-bold mb-4">Login</h2>

  <% if (error) { %>
    <p class="text-red-500"><%= error %></p>
  <% } %>

  <form method="POST">
    <input name="email" placeholder="Email" class="w-full border p-2 mb-3" required />
    <input type="password" name="password" placeholder="Password" class="w-full border p-2 mb-3" required />
    <button class="bg-blue-500 text-white px-4 py-2 w-full">Login</button>
  </form>

  <p class="mt-3 text-sm">No account? <a href="/register" class="text-blue-500">Register</a></p>
</div>

<%- include('partials/footer') %>
